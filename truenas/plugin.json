{
  "name": "truenas",
  "version": "0.1.0",
  "description": "TrueNAS Scale интеграция: управление пулами, датасетами, снапшотами и шарами через REST API v2.",
  "author": "Home Console",
  "class_path": "plugins.truenas.plugin.TrueNASPlugin",
  "role": "integration",
  "dependencies": [],
  "namespace": "truenas",
  "provides_services": [
    "truenas.system.info",
    "truenas.pool.list",
    "truenas.dataset.list",
    "truenas.dataset.create",
    "truenas.dataset.delete",
    "truenas.snapshot.list",
    "truenas.snapshot.create",
    "truenas.snapshot.delete",
    "truenas.share.smb.list",
    "truenas.share.nfs.list",
    "truenas.alert.list",
    "truenas.status"
