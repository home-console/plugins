{
  "class_path": "plugins.yandex_smart_home.plugin.YandexSmartHomeRealPlugin",
  "name": "yandex_smart_home",
  "version": "0.1.0",
  "description": "Интеграция с Яндекс Умным Домом - синхронизация реальных устройств",
  "author": "Home Console",
  "dependencies": [
    "oauth_yandex"
  ],
  "namespace": "yandex",
  "allowed_services": [
    "logger.*",
    "devices.auto_map_own",
    "devices.get",
    "devices.update_device_fields",
    "yandex_device_auth.refresh_cookies"
  ],
  "provides_events": [
    "external.device_discovered",
    "external.device_state_reported"
  ],
  "storage_namespaces": [
    "devices",
    "devices_mappings",
    "yandex"
  ],
  "is_integration": true,
  "integration_name": "Yandex Smart Home",
  "integration_flags": [
    "requires_oauth"
  ],
  "contract": {
    "consumes_services": [
      {
        "service": "oauth_yandex.get_access_token",
        "reason": "Получить access_token для Яндекс API"
      },
      {
        "service": "yandex_device_auth.get_session",
        "reason": "Управление авторизацией устройств"
      },
      {
        "service": "yandex_device_auth.refresh_cookies",
        "reason": "Обновить Quasar cookies для POST-команд"
      },
      {
        "service": "devices.get",
        "reason": "Сброс pending-состояния при ошибке команды"
      },
      {
        "service": "devices.update_device_fields",
        "reason": "Обновление state устройства после ошибки команды"
      },
      {
        "service": "devices.auto_map_own",
        "reason": "Регистрация и обновление устройств в Core"
      }
    ],
    "subscribes_events": [
      {
        "event": "internal.device_command_requested",
        "reason": "Выполнение команд на устройствах"
      },
      {
        "event": "yandex.device_auth.linked",
        "reason": "Инициировать синхронизацию после привязки"
      }
    ],
    "capabilities_required": [
      "oauth:yandex",
      "yandex:session_cookies"
    ],
    "provides_services": [],
    "provides_events": [],
    "capabilities_provided": []
  },
  "permissions": [
    {
      "id": "yandex.account",
      "title": "Аккаунт Яндекс",
      "description": "Читать и обновлять токен для API Умного дома",
      "sensitivity": "high",
      "requires": {
        "capabilities": ["oauth:yandex"],
        "services": ["oauth_yandex.get_access_token"]
      }
    },
    {
      "id": "yandex.device_sessions",
      "title": "Сессии устройств",
      "description": "Получать cookies после QR-привязки устройств к аккаунту",
      "sensitivity": "high",
      "requires": {
        "capabilities": ["yandex:session_cookies"],
        "services": ["yandex_device_auth.get_session"],
        "events": ["yandex.device_auth.linked"]
      }
    },
    {
      "id": "yandex.devices",
      "title": "Ваши устройства",
      "description": "Регистрировать устройства в Home Console и отправлять команды (вкл/выкл, яркость и др.)",
      "sensitivity": "medium",
      "requires": {
        "services": ["devices.auto_map_own"],
        "events": ["internal.device_command_requested"]
      }
    }
  ]
}
